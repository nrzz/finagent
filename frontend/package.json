    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.17.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "vite": "^6.0.6",
    "vite-plugin-pwa": "^0.21.2",
    "vitest": "^2.1.8",
    "@playwright/test": "^1.49.1",
    "openapi-typescript": "^7.4.4"
  }
